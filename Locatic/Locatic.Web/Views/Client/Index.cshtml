@model IEnumerable<Locatic.Application.DTOs.ClientDto>

<h1>Clients</h1>
<a asp-action="Create">Ajouter un client</a>

<table>
    <thead>
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.LastName</td>
                <td>@client.FirstName</td>
                <td>@client.Email</td>
                <td>@client.PhoneNumber</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@client.Id">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>

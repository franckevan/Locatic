@model Locatic.Application.DTOs.CreateReservationDto

<h1>Nouvelle réservation</h1>

@if (!ViewData.ModelState.IsValid)
{
    <ul>
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <li>@error.ErrorMessage</li>
        }
    </ul>
}

<form asp-action="Create" method="post">
    <div>
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" />
    </div>
    <div>
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" />
    </div>
    <div>
        <label>Voiture</label>
        <select asp-for="CarId">
            @foreach (var car in ViewBag.Cars)
            {
                <option value="@car.Id">@car.BrandName @car.ModelName - @car.LicensePlate</option>
            }
        </select>
    </div>
    <div>
        <label>Client</label>
        <select asp-for="ClientId">
            @foreach (var client in ViewBag.Clients)
            {
                <option value="@client.Id">@client.LastName @client.FirstName</option>
            }
        </select>
    </div>
    <button type="submit">Réserver</button>
</form>

<a asp-action="Index">Retour</a>

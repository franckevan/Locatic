<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Locatic.Web</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<div class="page">

    <header class="app-header">
        <nav class="app-navbar">

            <a class="app-logo"
               asp-controller="Home"
               asp-action="Index">
                Locatic.Web
            </a>

            <div class="app-menu">

                <a asp-controller="Home" asp-action="Index">
                    Accueil
                </a>

                <a asp-controller="Car" asp-action="Index">
                    Voitures
                </a>

                <a asp-controller="Brand" asp-action="Index">
                    Marques
                </a>

                <a asp-controller="CarModel" asp-action="Index">
                    Modèles
                </a>

                <a asp-controller="Client" asp-action="Index">
                    Clients
                </a>

                <a asp-controller="Reservation" asp-action="Index">
                    Réservations
                </a>

            </div>

        </nav>
    </header>

    <div class="app-container">

        <main role="main">
            @RenderBody()
        </main>

    </div>

</div>

<footer class="app-footer">
    © 2026 Locatic.Web - Gestion de location de voitures
</footer>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
        static_configs:
          - targets: ["kube-state-metrics:8080"]
      - job_name: prometheus
        static_configs:
          - targets: ["localhost:9090"]
  rules.yml: |
    groups:
      - name: locatic-alerts
        rules:
          - alert: AppDown
            expr: up{job="locatic-app"} == 0
            for: 1m
            labels:
              severity: critical
            annotations:
              summary: "L'application Locatic ne répond plus"
              description: "Le endpoint /metrics de locatic-app est injoignable depuis 1 minute."
          - alert: NginxDown
            expr: up{job="nginx"} == 0
            for: 1m labels:
              severity: critical
            annotations:
              summary: "Nginx ne répond plus"
              description: "L'exporter de métriques Nginx est injoignable depuis 1 minute."
          - alert: SqlitePvcNotBound
            expr: kube_persistentvolumeclaim_status_phase{namespace="{{ k8s_namespace }}", phase="Bound"} == 0

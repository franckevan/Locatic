apiVersion: apps/v1
kind: Deployment
metadata:
  name: locatic-app
  namespace: {{ k8s_namespace }}
  labels:
    app: locatic-app
spec:
  replicas: {{ app_replicas | default(1) }}
  selector:
    matchLabels:
      app: locatic-app
  template:
    metadata:
      labels:
        app: locatic-app
    spec:
      securityContext:
        fsGroup: 1000
      containers:
        - name: locatic-web
          image: "{{ app_image_name }}:{{ app_image_tag }}"
          imagePullPolicy: {{ app_image_pull_policy | default('IfNotPresent') }}
          ports:
            - containerPort: 8080
          envFrom:
            - configMapRef:
                name: locatic-config
          volumeMounts:
            - name: sqlite-data
              mountPath: /data
          readinessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "256Mi"
      volumes:
        - name: sqlite-data
          persistentVolumeClaim:
            claimName: {{ sqlite_pvc_name }}
